; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="EmblemFighter"
run/main_scene="res://battle/Battle.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Skills="*res://autoloads/Skills.gd"
Passives="*res://autoloads/Passives.gd"
Equipment="*res://autoloads/Equipment.gd"
Heroes="*res://autoloads/Heroes.gd"
Enemies="*res://autoloads/Enemies.gd"
Combat="*res://autoloads/Combat.gd"
Utils="*res://autoloads/Utils.gd"
UITheme="*res://autoloads/UITheme.gd"
PlayerInventory="*res://autoloads/PlayerInventory.gd"
RoomLibrary="*res://autoloads/RoomLibrary.gd"
BuffDebuff="*res://autoloads/BuffDebuff.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[rendering]

textures/canvas_textures/default_texture_filter=0
